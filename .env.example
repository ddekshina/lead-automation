# ============================================================
# Lead Automation — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# --- AI (required) ---
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: override default model (falls back automatically on errors)
# GEMINI_MODEL=gemini-2.5-flash

# --- Email Delivery (required for email sending) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SENDER_EMAIL=your_email@gmail.com

# --- Google Sheets + Drive (optional bonus features) ---
# Path to a Google Cloud service account JSON key file
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account.json
# Spreadsheet ID from the Google Sheet URL
GOOGLE_SHEET_ID=your_spreadsheet_id
# Drive folder ID where PDFs will be archived (create in YOUR Gmail Drive)
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id
# Personal Gmail: OAuth token for Drive uploads (run scripts/authorize_google_drive.py)
# GOOGLE_DRIVE_TOKEN_JSON=google_drive_token.json
# OAuth desktop client secret from Google Cloud (for authorize script only)
# GOOGLE_OAUTH_CLIENT_JSON=google_oauth_client.json
